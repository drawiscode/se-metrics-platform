# DevInsight 后端配置文件
# 复制本文件为 config.env 并填入实际值: cp config.env.example config.env

# SQLite 数据库文件路径（绝对路径）
DEVINSIGHT_DB=/your/path/to/data/devinsight.db

# 服务端口
PORT=8080

# GitHub Personal Access Token（用于从 GitHub API 同步仓库数据）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ---- 2.4 AI 模块配置（可选，不配则 AI 问答不可用）----
# LLM API 地址（兼容 OpenAI Chat Completions 格式）
# OpenAI:    https://api.openai.com
# DeepSeek:  https://api.deepseek.com
# 阿里通义:  https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_BASE=https://api.openai.com

# LLM API Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 模型名称
LLM_MODEL=gpt-3.5-turbo
